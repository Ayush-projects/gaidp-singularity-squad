<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Intelligent MQ Topology Simplification</title>
<style>
  /* ── reset & base ──────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ibm-blue:    #0f62fe;
    --ibm-blue-lt: #4589ff;
    --cyan:        #00b4d8;
    --cyan-lt:     #90e0ef;
    --purple:      #7c3aed;
    --purple-lt:   #a78bfa;
    --green:       #00d084;
    --amber:       #f59e0b;
    --red:         #ef4444;
    --bg:          #060b18;
    --bg2:         #0d1525;
    --bg3:         #111c33;
    --card:        #14213d;
    --border:      rgba(79,140,255,.18);
    --text:        #e2e8f0;
    --muted:       #94a3b8;
    --white:       #ffffff;
  }

  html, body {
    height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    overflow: hidden;
  }

  /* ── slide container ──────────────────────────────────────────── */
  #deck {
    width: 100vw;
    height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 40px 60px;
    opacity: 0;
    pointer-events: none;
    transform: translateX(80px);
    transition: opacity .55s cubic-bezier(.4,0,.2,1),
                transform .55s cubic-bezier(.4,0,.2,1);
  }
  .slide.active {
    opacity: 1;
    pointer-events: all;
    transform: translateX(0);
  }
  .slide.exit {
    opacity: 0;
    transform: translateX(-80px);
  }

  /* ── background mesh ──────────────────────────────────────────── */
  .slide::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 20%, rgba(15,98,254,.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 80% 80%, rgba(0,180,216,.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 60% 10%, rgba(124,58,237,.06) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .slide > * { position: relative; z-index: 1; }

  /* ── grid overlay decoration ──────────────────────────────────── */
  #grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(15,98,254,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15,98,254,.04) 1px, transparent 1px);
    background-size: 50px 50px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── progress bar ─────────────────────────────────────────────── */
  #progress {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--ibm-blue), var(--cyan));
    transition: width .4s ease;
    z-index: 100;
    box-shadow: 0 0 12px var(--cyan);
  }

  /* ── slide counter ────────────────────────────────────────────── */
  #counter {
    position: fixed;
    bottom: 28px; right: 28px;
    font-size: .8rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    z-index: 100;
  }

  /* ── nav arrows ───────────────────────────────────────────────── */
  .nav-btn {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    width: 48px; height: 48px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(14,33,61,.8);
    backdrop-filter: blur(12px);
    color: var(--cyan-lt);
    font-size: 1.3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s, border-color .2s, transform .2s;
  }
  .nav-btn:hover {
    background: rgba(15,98,254,.3);
    border-color: var(--ibm-blue);
    transform: translateY(-50%) scale(1.1);
  }
  #prev { left: 16px; }
  #next { right: 16px; }

  /* ── dot nav ──────────────────────────────────────────────────── */
  #dots {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 100;
  }
  .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--muted);
    cursor: pointer;
    transition: background .2s, transform .2s, width .3s;
  }
  .dot.active {
    background: var(--cyan);
    width: 22px;
    border-radius: 4px;
    box-shadow: 0 0 8px var(--cyan);
  }

  /* ── logo badge ───────────────────────────────────────────────── */
  #logo {
    position: fixed;
    top: 18px; left: 24px;
    font-size: .72rem;
    letter-spacing: .14em;
    color: var(--muted);
    text-transform: uppercase;
    z-index: 100;
    display: flex; align-items: center; gap: 8px;
  }
  #logo span {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--ibm-blue);
    box-shadow: 0 0 8px var(--ibm-blue);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:.5; transform:scale(.8); }
  }

  /* ── typography helpers ───────────────────────────────────────── */
  .badge {
    display: inline-block;
    padding: 4px 14px;
    border-radius: 20px;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .badge-blue  { background: rgba(15,98,254,.2); color: var(--ibm-blue-lt); border: 1px solid rgba(15,98,254,.3); }
  .badge-cyan  { background: rgba(0,180,216,.15); color: var(--cyan); border: 1px solid rgba(0,180,216,.3); }
  .badge-purple{ background: rgba(124,58,237,.2); color: var(--purple-lt); border: 1px solid rgba(124,58,237,.3); }
  .badge-green { background: rgba(0,208,132,.15); color: var(--green); border: 1px solid rgba(0,208,132,.3); }
  .badge-amber { background: rgba(245,158,11,.15); color: var(--amber); border: 1px solid rgba(245,158,11,.3); }

  .slide-title {
    font-size: clamp(1.7rem, 3vw, 2.8rem);
    font-weight: 700;
    line-height: 1.2;
    background: linear-gradient(135deg, var(--white) 30%, var(--cyan-lt) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
    text-align: center;
  }
  .slide-sub {
    font-size: clamp(.85rem, 1.5vw, 1.05rem);
    color: var(--muted);
    text-align: center;
    margin-bottom: 32px;
    max-width: 680px;
    line-height: 1.6;
  }

  /* ── card ─────────────────────────────────────────────────────── */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 26px;
    backdrop-filter: blur(10px);
  }
  .card-title {
    font-size: .8rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 12px;
  }

  /* ── grid layouts ─────────────────────────────────────────────── */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; width: 100%; max-width: 1100px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; width: 100%; max-width: 1100px; }
  .grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 14px; width: 100%; max-width: 1100px; }

  /* ── stat block ───────────────────────────────────────────────── */
  .stat {
    text-align: center;
    padding: 20px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }
  .stat::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ibm-blue), var(--cyan));
  }
  .stat-num {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    background: linear-gradient(135deg, var(--cyan), var(--ibm-blue-lt));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-label { font-size: .78rem; color: var(--muted); margin-top: 4px; }

  /* ── code block ───────────────────────────────────────────────── */
  .code {
    background: #080f1e;
    border: 1px solid rgba(15,98,254,.2);
    border-radius: 10px;
    padding: 16px 20px;
    font-family: 'Consolas', 'Fira Code', monospace;
    font-size: clamp(.72rem, 1.1vw, .88rem);
    line-height: 1.7;
    color: #cdd6f4;
    width: 100%;
    overflow-x: auto;
  }
  .kw  { color: var(--purple-lt); }
  .fn  { color: var(--cyan); }
  .str { color: var(--green); }
  .cm  { color: #6c7086; }
  .num { color: var(--amber); }

  /* ── pipeline ─────────────────────────────────────────────────── */
  .pipeline {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: 1050px;
    flex-wrap: nowrap;
  }
  .pipe-step {
    flex: 1;
    text-align: center;
    padding: 14px 10px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: .78rem;
    line-height: 1.5;
  }
  .pipe-step .icon { font-size: 1.4rem; margin-bottom: 6px; display: block; }
  .pipe-arrow {
    font-size: 1.2rem;
    color: var(--cyan);
    padding: 0 6px;
    flex-shrink: 0;
  }

  /* ── formula box ──────────────────────────────────────────────── */
  .formula {
    background: linear-gradient(135deg, rgba(15,98,254,.1), rgba(0,180,216,.08));
    border: 1px solid rgba(0,180,216,.25);
    border-radius: 12px;
    padding: 18px 28px;
    font-size: clamp(.9rem, 1.4vw, 1.1rem);
    font-family: 'Consolas', monospace;
    color: var(--cyan-lt);
    text-align: center;
  }

  /* ── list items ───────────────────────────────────────────────── */
  ul.fancy { list-style: none; }
  ul.fancy li {
    padding: 7px 0 7px 24px;
    position: relative;
    font-size: clamp(.8rem, 1.2vw, .95rem);
    color: var(--text);
    border-bottom: 1px solid rgba(255,255,255,.04);
  }
  ul.fancy li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--cyan);
    font-weight: 700;
  }
  ul.fancy li:last-child { border: none; }

  /* ── comparison table ─────────────────────────────────────────── */
  .compare {
    width: 100%;
    border-collapse: collapse;
    font-size: clamp(.72rem, 1.1vw, .88rem);
  }
  .compare th {
    padding: 10px 14px;
    font-size: .72rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--cyan);
    background: rgba(0,180,216,.08);
    border-bottom: 1px solid var(--border);
    text-align: left;
  }
  .compare td {
    padding: 9px 14px;
    border-bottom: 1px solid rgba(255,255,255,.04);
    color: var(--text);
    vertical-align: top;
  }
  .compare tr:hover td { background: rgba(255,255,255,.02); }
  .tag {
    display: inline-block;
    padding: 2px 9px;
    border-radius: 4px;
    font-size: .7rem;
    font-weight: 600;
  }
  .tag-green { background: rgba(0,208,132,.15); color: var(--green); }
  .tag-amber { background: rgba(245,158,11,.15); color: var(--amber); }
  .tag-red   { background: rgba(239,68,68,.15); color: var(--red); }
  .tag-blue  { background: rgba(15,98,254,.2); color: var(--ibm-blue-lt); }

  /* ── topology diagram ─────────────────────────────────────────── */
  .topo {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    width: 100%;
    max-width: 1050px;
    justify-content: center;
  }
  .topo-side {
    flex: 1;
    max-width: 460px;
  }
  .topo-label {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 12px;
    text-align: center;
  }
  .topo-label.before { color: var(--red); }
  .topo-label.after  { color: var(--green); }

  svg.topo-svg { width: 100%; height: 220px; }

  /* ── divider ──────────────────────────────────────────────────── */
  .divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
    margin: 18px 0;
  }

  /* ── metric bar ───────────────────────────────────────────────── */
  .metric-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .metric-label { font-size: .78rem; color: var(--muted); width: 160px; flex-shrink: 0; }
  .metric-bar-bg {
    flex: 1;
    height: 8px;
    background: rgba(255,255,255,.06);
    border-radius: 4px;
    overflow: hidden;
  }
  .metric-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 1.2s cubic-bezier(.4,0,.2,1);
  }
  .metric-val { font-size: .78rem; color: var(--cyan); width: 48px; text-align: right; flex-shrink: 0; }

  /* ── step badge ───────────────────────────────────────────────── */
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ibm-blue), var(--cyan));
    font-size: .8rem;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
    margin-right: 10px;
  }
  .step-row {
    display: flex;
    align-items: flex-start;
    margin-bottom: 12px;
  }
  .step-text { font-size: clamp(.8rem, 1.2vw, .92rem); color: var(--text); line-height: 1.5; }

  /* ── glow button ──────────────────────────────────────────────── */
  .glow-btn {
    display: inline-block;
    padding: 12px 32px;
    border-radius: 30px;
    background: linear-gradient(135deg, var(--ibm-blue), var(--cyan));
    color: white;
    font-weight: 700;
    font-size: .9rem;
    letter-spacing: .04em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    box-shadow: 0 0 24px rgba(0,180,216,.35);
    transition: transform .2s, box-shadow .2s;
    margin-top: 24px;
  }
  .glow-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 40px rgba(0,180,216,.55);
  }

  /* ── anim helpers ─────────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(20px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .slide.active .anim { animation: fadeUp .5s both; }
  .slide.active .anim:nth-child(1) { animation-delay: .05s; }
  .slide.active .anim:nth-child(2) { animation-delay: .12s; }
  .slide.active .anim:nth-child(3) { animation-delay: .19s; }
  .slide.active .anim:nth-child(4) { animation-delay: .26s; }
  .slide.active .anim:nth-child(5) { animation-delay: .33s; }
  .slide.active .anim:nth-child(6) { animation-delay: .40s; }
  .slide.active .anim:nth-child(7) { animation-delay: .47s; }
  .slide.active .anim:nth-child(8) { animation-delay: .54s; }

  /* ── wide wrapper ─────────────────────────────────────────────── */
  .w-full { width: 100%; max-width: 1100px; }

  /* ── hero gradient text ───────────────────────────────────────── */
  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 800;
    text-align: center;
    line-height: 1.1;
    background: linear-gradient(135deg, #ffffff 0%, var(--cyan-lt) 40%, var(--ibm-blue-lt) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 14px;
  }
  .hero-sub {
    font-size: clamp(.9rem, 1.6vw, 1.15rem);
    color: var(--muted);
    text-align: center;
    max-width: 700px;
    line-height: 1.7;
    margin-bottom: 30px;
  }

  /* ── tag row ──────────────────────────────────────────────────── */
  .tag-row { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 20px; }

  /* ── horizontal rule ──────────────────────────────────────────── */
  hr { border: none; border-top: 1px solid var(--border); margin: 16px 0; }

  /* ── scroll inner ─────────────────────────────────────────────── */
  .inner { width: 100%; max-width: 1100px; }

  /* ── flowing chart (lexicographic objective) ──────────────────── */
  .lex-row {
    display: flex;
    align-items: stretch;
    gap: 8px;
    width: 100%;
    max-width: 960px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .lex-item {
    flex: 1;
    min-width: 110px;
    text-align: center;
    padding: 12px 8px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--card);
    position: relative;
  }
  .lex-item .lex-rank {
    position: absolute;
    top: -10px; left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--ibm-blue), var(--cyan));
    width: 22px; height: 22px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .68rem;
    font-weight: 700;
    color: white;
  }
  .lex-item .lex-name { font-size: .78rem; color: var(--text); margin-top: 8px; }
  .lex-item .lex-desc { font-size: .68rem; color: var(--muted); margin-top: 4px; line-height: 1.4; }

  /* ── node types visual ────────────────────────────────────────── */
  .node-types { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
  .node-pill {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 14px;
    border-radius: 30px;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: .8rem;
  }
  .node-circle {
    width: 14px; height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── constraint list ──────────────────────────────────────────── */
  .constraint {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 16px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 10px;
  }
  .constraint-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 1px; }
  .constraint-title { font-size: .85rem; font-weight: 600; color: var(--text); }
  .constraint-desc { font-size: .75rem; color: var(--muted); margin-top: 2px; line-height: 1.5; }

  /* ── before/after topology svg ────────────────────────────────── */
  .topo-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
  }

  /* slide 1 star bg */
  #stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .star {
    position: absolute;
    border-radius: 50%;
    animation: twinkle var(--d) infinite;
    opacity: var(--o);
  }
  @keyframes twinkle {
    0%,100% { opacity: var(--o); }
    50% { opacity: calc(var(--o) * .2); }
  }

  /* ── anomaly badge strip ──────────────────────────────────────── */
  .anomaly-strip {
    display: flex; flex-wrap: wrap; gap: 10px;
    justify-content: center; width: 100%;
  }
  .anomaly-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 18px;
    text-align: center;
    min-width: 160px;
    flex: 1;
  }
  .anomaly-icon { font-size: 1.5rem; margin-bottom: 6px; display: block; }
  .anomaly-name { font-size: .82rem; font-weight: 600; color: var(--text); }
  .anomaly-desc { font-size: .7rem; color: var(--muted); margin-top: 3px; }

  /* ── result metric ────────────────────────────────────────────── */
  .result-block {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .result-block::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ibm-blue), var(--cyan), var(--green));
  }
  .result-num {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800;
    background: linear-gradient(135deg, var(--green), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .result-label { font-size: .8rem; color: var(--muted); margin-top: 4px; }

  /* ── arch boxes ───────────────────────────────────────────────── */
  .arch-layer {
    display: flex;
    gap: 12px;
    width: 100%;
    max-width: 1050px;
    margin-bottom: 10px;
    align-items: stretch;
  }
  .arch-box {
    flex: 1;
    padding: 14px 16px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-align: center;
    font-size: .8rem;
  }
  .arch-box .arch-icon { font-size: 1.3rem; margin-bottom: 5px; display: block; }
  .arch-box .arch-name { font-weight: 600; color: var(--text); margin-bottom: 3px; }
  .arch-box .arch-tech { font-size: .68rem; color: var(--muted); }
  .arch-layer-label {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-size: .68rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-right: 8px;
    min-width: 20px;
