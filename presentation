<!-- ── SLIDE 04 · DATA MODEL ─────────────────────────────────────── -->
<section class="slide" data-title="Graph Model">
  <div class="badge badge-purple anim">Data &amp; Graph Model</div>
  <h2 class="slide-title anim">NetworkX Directed Graph Representation</h2>
  <p class="slide-sub anim">We model the entire MQ environment as a typed directed property graph for analysis and optimization.</p>

  <div class="grid-2 anim" style="max-width:960px">
    <div class="card">
      <div class="card-title">Node Types</div>
      <div class="node-types" style="justify-content:flex-start;margin-bottom:12px">
        <div class="node-pill"><div class="node-circle" style="background:#0f62fe"></div>app:{app_id}</div>
        <div class="node-pill"><div class="node-circle" style="background:#00b4d8"></div>qm:{qm_name}</div>
        <div class="node-pill"><div class="node-circle" style="background:#7c3aed"></div>queue:{name}@{qm}</div>
        <div class="node-pill"><div class="node-circle" style="background:#f59e0b"></div>chan:{QM1}→{QM2}</div>
      </div>
      <div class="divider"></div>
      <div class="card-title">Edge Types</div>
      <ul class="fancy">
        <li><code style="color:var(--cyan)">PRODUCES_TO</code>  app → queue</li>
        <li><code style="color:var(--green)">CONSUMES_FROM</code>  queue → app</li>
        <li><code style="color:var(--purple-lt)">HOSTED_ON</code>  queue → qm</li>
        <li><code style="color:var(--amber)">ROUTES_TO</code>  queue → remote_queue (cross-QM)</li>
        <li><code style="color:var(--ibm-blue-lt)">HAS_CHANNEL</code>  qm → channel</li>
        <li><code style="color:var(--muted)">CONNECTS_TO</code>  channel → target qm</li>
      </ul>
    </div>
    <div class="card">
      <div class="card-title">Analytics Derived from Graph</div>
      <ul class="fancy">
        <li><strong>Fanout</strong> — queues each producer distributes to (max = bottleneck)</li>
        <li><strong>Fan-in</strong> — queues each consumer reads from</li>
        <li><strong>App-QM mapping</strong> — which QMs each app currently touches</li>
        <li><strong>Shortest paths</strong> — message routing depth (all-pairs)</li>
        <li><strong>Graph density</strong> — edges / nodes² (connectivity concentration)</li>
        <li><strong>Cycle detection</strong> — DFS via nx.find_cycle() (O(V+E))</li>
        <li><strong>Cross-QM routes</strong> — ROUTES_TO edge count (inter-manager hops)</li>
      </ul>
      <div class="divider"></div>
      <div class="code">
<span class="kw">def</span> <span class="fn">build_graph</span>(records):
  G = nx.DiGraph()
  <span class="kw">for</span> r <span class="kw">in</span> records:
    G.add_node(<span class="str">f"app:{r.app_id}"</span>, type=<span class="str">"app"</span>)
    G.add_node(<span class="str">f"qm:{r.qm}"</span>,   type=<span class="str">"qm"</span>)
    G.add_edge(<span class="str">f"app:{r.app_id}"</span>, <span class="str">f"queue:{r.queue}"</span>,
               edge_type=<span class="str">"PRODUCES_TO"</span>)
      </div>
    </div>
  </div>
</section>

<!-- ── SLIDE 05 · COMPLEXITY SCORE ──────────────────────────────── -->
<section class="slide" data-title="Complexity Score">
  <div class="badge badge-amber anim">Complexity Algorithm</div>
  <h2 class="slide-title anim">Mixed-Radix Hierarchical Complexity Score</h2>
  <p class="slide-sub anim">A single comparable integer that encodes seven dimensions of topology health — most-significant first.</p>

  <div class="formula anim">
    score = C₁ · (B₂·B₃·B₄·B₅·B₆·B₇) + C₂ · (B₃·…·B₇) + … + C₇
  </div>

  <div class="grid-2 anim" style="margin-top:18px; max-width:960px">
    <div class="card">
      <div class="card-title">Components (most → least significant)</div>
      <table class="compare">
        <thead><tr><th>#</th><th>Component</th><th>How measured</th></tr></thead>
        <tbody>
          <tr><td><span class="tag tag-red">1</span></td><td>Cycles</td><td>Boolean: nx.find_cycle() hit</td></tr>
          <tr><td><span class="tag tag-amber">2</span></td><td>Channels</td><td>Count sender/receiver pairs</td></tr>
          <tr><td><span class="tag tag-amber">3</span></td><td>Cross-QM routes</td><td>ROUTES_TO edge count</td></tr>
          <tr><td><span class="tag tag-blue">4</span></td><td>Max fan-out</td><td>Max queues per producer</td></tr>
          <tr><td><span class="tag tag-blue">5</span></td><td>Queue managers</td><td>Active QM count</td></tr>
          <tr><td><span class="tag tag-green">6</span></td><td>Total queues</td><td>Queue node count</td></tr>
          <tr><td><span class="tag tag-green">7</span></td><td>Avg path length</td><td>Mean shortest path (undirected)</td></tr>
        </tbody>
      </table>
    </div>
    <div class="card">
      <div class="card-title">Implementation</div>
      <div class="code">
<span class="kw">def</span> <span class="fn">mixed_radix_score</span>(components, bounds):
  <span class="cm"># components: [cycles, channels, cross_qm,</span>
  <span class="cm">#              fanout, qms, queues, avg_path]</span>
  score = components[<span class="num">0</span>]
  <span class="kw">for</span> comp, bound <span class="kw">in</span> zip(
        components[<span class="num">1</span>:], bounds):
    score = score * (bound + <span class="num">1</span>) + comp
  <span class="kw">return</span> score
      </div>
      <div class="divider"></div>
      <div class="card-title">Why Mixed-Radix?</div>
      <ul class="fancy">
        <li>Encodes priority: eliminating a cycle always beats reducing channels</li>
        <li>Produces a <strong>single comparable integer</strong> — easy to rank strategies</li>
        <li>Bounds are dynamic per-dataset (max observed per metric)</li>
        <li>Lower score = strictly simpler topology</li>
      </ul>
    </div>
  </div>
</section>

