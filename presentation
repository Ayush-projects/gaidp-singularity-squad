<script>
// ── star field ────────────────────────────────────────────────────
(function(){
  const container = document.getElementById('stars');
  for(let i=0;i<120;i++){
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random()*2+1;
    s.style.cssText = `
      width:${size}px;height:${size}px;
      top:${Math.random()*100}%;left:${Math.random()*100}%;
      background:rgba(255,255,255,${Math.random()*.7+.1});
      --d:${(Math.random()*4+2).toFixed(1)}s;
      --o:${(Math.random()*.5+.1).toFixed(2)};
      animation-delay:${(Math.random()*4).toFixed(1)}s;
    `;
    container.appendChild(s);
  }
})();

// ── slides ────────────────────────────────────────────────────────
const slides = Array.from(document.querySelectorAll('.slide'));
let current = 0;

function buildDots(){
  const dots = document.getElementById('dots');
  slides.forEach((_,i)=>{
    const d = document.createElement('div');
    d.className = 'dot' + (i===0?' active':'');
    d.onclick = ()=>goTo(i);
    dots.appendChild(d);
  });
}

function updateProgress(){
  const pct = slides.length>1 ? (current/(slides.length-1))*100 : 100;
  document.getElementById('progress').style.width = pct+'%';
}

function updateCounter(){
  document.getElementById('counter').textContent =
    `${current+1} / ${slides.length}`;
}

function updateDots(){
  document.querySelectorAll('.dot').forEach((d,i)=>{
    d.classList.toggle('active', i===current);
  });
}

function goTo(idx){
  if(idx===current||idx<0||idx>=slides.length) return;
  slides[current].classList.remove('active');
  slides[current].classList.add('exit');
  const prev = current;
  current = idx;
  setTimeout(()=>{ slides[prev].classList.remove('exit'); }, 600);
  slides[current].classList.add('active');
  updateProgress();
  updateCounter();
  updateDots();
}

function changeSlide(dir){ goTo(current+dir); }

// Keyboard nav
document.addEventListener('keydown', e=>{
  if(e.key==='ArrowRight'||e.key==='ArrowDown'||e.key===' ') changeSlide(1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp') changeSlide(-1);
});

// Touch swipe
let touchX=0;
document.addEventListener('touchstart',e=>{ touchX=e.changedTouches[0].screenX; },{passive:true});
document.addEventListener('touchend',e=>{
  const dx = e.changedTouches[0].screenX - touchX;
  if(Math.abs(dx)>50) changeSlide(dx<0?1:-1);
},{passive:true});

// Init
buildDots();
slides[0].classList.add('active');
updateProgress();
updateCounter();
</script>
