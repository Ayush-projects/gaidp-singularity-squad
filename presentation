    </div>
  </div>

  <div class="grid-2 anim" style="margin-top:18px; max-width:940px">
    <div class="card">
      <div class="card-title">Mixed-Radix Encoding</div>
      <div class="code">
<span class="cm"># Bases derived from worst-case bounds</span>
total = components[<span class="num">0</span>]
<span class="kw">for</span> c, base <span class="kw">in</span> zip(
      components[<span class="num">1</span>:], bases):
  total = total * base + c
<span class="cm"># One integer — fully comparable across</span>
<span class="cm"># strategies and optimization runs</span>
      </div>
    </div>
    <div class="card">
      <div class="card-title">CP-SAT Weighted Objective (parallel)</div>
      <div class="code">
minimize: α·channels
        + β·cross_qm_hops   <span class="cm"># ×2.0</span>
        + γ·cross_lob_flows  <span class="cm"># ×0.5</span>
        + δ·new_objects
        + ε·fanout_variance
        + ζ·risky_moves      <span class="cm"># ×5.0</span>
